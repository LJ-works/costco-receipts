{
  "name": "costco-userjs",
  "version": "1.0.0",
  "description": "Costco userscript",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.3",
    "vite-plugin-monkey": "^8.0.6",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "dependencies": {
    "idb-keyval": "^6.3.0"
  }
}
